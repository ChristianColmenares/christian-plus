---
import type { SiteContent } from '../content/site';
import Icon from './Icon.astro';
import SectionHeading from './SectionHeading.astro';
import TagList from './TagList.astro';

interface Props {
  content: SiteContent;
}

const { content } = Astro.props;
---

<section class="py-section-gap" id="experience">
  <SectionHeading title={content.experience.heading} />
  <div class="flex flex-col gap-8">
    {
      content.experience.projects.map((project) => (
        <article class="flex flex-col gap-8 rounded border border-surface-variant bg-surface-container-lowest p-8 md:flex-row">
          <div class="flex flex-col gap-2 md:w-1/3">
            <div class="font-label-sm text-label-sm text-secondary">{project.period}</div>
            <h3 class="font-headline-lg-mobile text-headline-lg-mobile text-primary md:font-headline-lg md:text-headline-lg">
              {project.title}
            </h3>
            <div class="mt-2 flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-primary"></span>
              <span class="font-label-sm text-label-sm text-secondary">{project.status}</span>
            </div>
          </div>
          <div class="flex flex-col gap-4 md:w-2/3">
            <p class="font-body-md text-body-md text-on-surface">{project.description}</p>
            <div class="mt-auto">
              <TagList items={project.tags} />
            </div>
          </div>
        </article>
      ))
    }

    <aside class="mt-8 flex flex-col items-center justify-between gap-8 rounded border border-surface-variant bg-primary p-8 text-on-primary md:flex-row md:p-12">
      <div class="flex max-w-xl flex-col gap-4">
        <h3 class="font-headline-lg-mobile text-headline-lg-mobile md:font-headline-lg md:text-headline-lg">
          {content.experience.cta.title}
        </h3>
        <p class="font-body-lg text-body-lg text-inverse-primary">
          {content.experience.cta.description}
        </p>
      </div>
      <div class="flex w-full shrink-0 flex-col gap-4 md:w-auto">
        <a
          class="flex items-center justify-center gap-2 rounded bg-primary-container px-8 py-4 font-label-md text-label-md text-on-primary transition-opacity hover:opacity-90"
          href={`mailto:${content.footer.email}`}
        >
          <Icon name="mail" />
          {content.experience.cta.emailLabel}
        </a>
        <div class="flex gap-4">
          {
            content.experience.cta.links.map((link) => (
              <a class="flex flex-1 items-center justify-center gap-2 rounded border border-outline px-4 py-3 font-label-md text-label-md text-on-primary transition-colors hover:bg-surface-tint/20" href={link.href}>
                {link.icon && <Icon name={link.icon} />}
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </aside>
  </div>
</section>
