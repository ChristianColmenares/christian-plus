---
interface Props {
  items: string[];
}

const { items } = Astro.props;
---

<div class="flex flex-wrap gap-2">
  {
    items.map((item) => (
      <span class="rounded bg-surface-container-low px-3 py-1 font-label-sm text-label-sm text-on-surface-variant">
        {item}
      </span>
    ))
  }
</div>
